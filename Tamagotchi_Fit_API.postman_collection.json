      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"user_12345\",\n  \"heartRate\": 125.5,\n  \"acceleration\": 12.8,\n  \"petState\": \"FELIZ\",\n  \"timestamp\": \"{{$isoTimestamp}}\",\n  \"deviceInfo\": {\n    \"model\": \"Pixel Watch 3\",\n    \"platform\": \"Wear OS 5\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sensor-data",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sensor-data"]
        },
        "description": "Registrar nuevos datos de sensor"
